# Local Assistant — environment template.
# Copy to .env and fill in real values. NEVER commit .env (see .gitignore).

# ── Telegram ──────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user id — the ONLY id the bot will respond to.
# Get it from @userinfobot. Comma-separate if more than one owner.
OWNER_CHAT_IDS=

# ── Ollama / models ───────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
MODEL_MAIN=qwen3.5:4b
MODEL_MAIN_FALLBACK=qwen3:4b-instruct
MODEL_ROUTER=qwen3:1.7b
MODEL_EMBED=embeddinggemma:300m
MODEL_DRAFT=qwen3:0.6b            # speculative-decoding draft model (see setup-pi.md)
# NOTE: speculative decoding & KV-cache type are `ollama serve` ENV vars, not per-request.
# Export them for the Ollama service (docs/setup-pi.md), e.g.:
#   OLLAMA_SPECULATIVE_DECODE=1  OLLAMA_KV_CACHE_TYPE=q8_0

# Context window. Capacity ceiling on Pi is ~32-64K (RAM), but prefill on CPU is
# slow, so keep the *working* context small and rely on RAG. See docs/architecture.md.
NUM_CTX=8192                      # max context handed to the model (per-request)
WORKING_CONTEXT_BUDGET=4096       # target tokens assembled per request (sys+RAG+recent)
NUM_THREADS=4                     # all 4 A76 cores (per-request)

# ── Storage ───────────────────────────────────────────────
DB_PATH=./data/assistant.db
MEMORY_MD_PATH=./data/MEMORY.md
DOC_INBOX_DIR=./docs/inbox
BACKUP_DIR=./backups

# ── Web search (ddgs — no service, queries go to DuckDuckGo) ──
SEARCH_REGION=ru-ru
SEARCH_MAX_RESULTS=5

# ── Apple / iCloud (optional) ─────────────────────────────
# Calendar + Reminders (CalDAV) and Contacts (CardDAV). Leave APPLE_ID blank to
# disable and run fully local. Use an APP-SPECIFIC password from appleid.apple.com
# (Security → App-Specific Passwords) — NOT your Apple ID password. Requires the
# data to be synced to iCloud (not "On My Mac").
APPLE_ID=
APPLE_APP_PASSWORD=
ICLOUD_CALENDAR_NAME=        # blank = first calendar that supports events
ICLOUD_REMINDERS_LIST=       # blank = first list that supports reminders
ICLOUD_SYNC_MINUTES=15

# ── Behaviour ─────────────────────────────────────────────
TIMEZONE=Europe/Moscow
MORNING_DIGEST=08:00
EVENING_DIGEST=21:00
NIGHTLY_REFLECTION=03:00
QUIET_HOURS=22:30-07:30
MAX_PROACTIVE_PER_DAY=4
